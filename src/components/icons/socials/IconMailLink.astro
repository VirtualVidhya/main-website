---
export interface Props {
  styleClass: string;
}

const { styleClass } = Astro.props;
---

<a
  class="link-interaction-effect flex justify-center items-center"
  href="mailto:contact@vvidhya.com"
  target="_blank"
  rel="noopener noreferrer"
  title="Email"
  aria-label="Email"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class=`social-icon ${styleClass}`
    ><path
      fill="currentColor"
      d="M3 3h18a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1m9.06 8.683L5.648 6.238L4.353 7.762l7.72 6.555l7.581-6.56l-1.308-1.513z"
      stroke-width="0"
      stroke="currentColor"></path></svg
  >
</a>
