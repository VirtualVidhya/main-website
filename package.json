{
  "name": "vvidhya.com",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "main": "functions/api/submit-contact-form.js",
  "scripts": {
    "build:worker": "esbuild functions/api/submit-contact-form.js --bundle --platform=node --external:resend --outfile=dist/worker.js",
    "build:astro": "astro build",
    "build": "npm run build:worker && npm run build:astro",
    "build:astro-watch": "astro build --watch",
    "dev:astro": "astro dev",
    "dev": "npm run build:astro && npm run build:worker && wrangler dev",
    "deploy": "wrangler deploy",
    "purgecss": "purgecss --css src/styles/fontawesome.css --content './**/*.html' --output src/styles/fontawesome.min.css",
    "log": "npx wrangler pages deployment tail"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.2",
    "fast-glob": "^3.3.2",
    "purgecss": "^6.0.0",
    "sharp": "^0.33.5",
    "svgo": "^3.3.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5",
    "wrangler": "^3.92.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^6.0.0",
    "@playform/compress": "^0.1.7",
    "astro": "^5.2.5",
    "astro-compressor": "^1.0.0",
    "chalk": "^5.4.1",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "swiper": "^11.1.15"
  }
}
